{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pocket Watch",
  "version": "0.1.0",
  "identifier": "com.pocketwatch.finance",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "Pocket Watch", "width": 1100, "height": 720 }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wombat-slayer/pocket-watch/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzNjdDMTVEQ0E0RUU0MTQKUldRVTVFN0tYY0ZuUS95RncrWnBTYk00OXpCUzYxSUp0eHB1bjB0Ulk3dWg5T3RKY01RNDRIUDcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
